# =============================================================================
#  GraphRAG Research Assistant — Environment Variables
#  Copy to .env and fill in real values.  NEVER commit .env to version control.
# =============================================================================

# ─────────────────────────── Mistral AI ──────────────────────────────────────
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_SMALL_MODEL=mistral-small-latest
MISTRAL_LARGE_MODEL=mistral-large-latest
# Timeout in seconds for each Mistral API call
MISTRAL_TIMEOUT=60
# Maximum number of retry attempts on transient errors (429, 5xx)
MISTRAL_MAX_RETRIES=3

# ─────────────────────────── Neo4j ────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password_here
NEO4J_DATABASE=neo4j

# ─────────────────────────── Pinecone ─────────────────────────────────────────
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=graphrag-research
# AWS region hosting your Pinecone serverless index
PINECONE_ENVIRONMENT=us-east-1

# ─────────────────────────── HuggingFace Inference API (cloud embeddings) ─────
# API token from https://huggingface.co/settings/tokens (requires read access)
HUGGINGFACE_API_TOKEN=your_huggingface_api_token_here
# Full model repo path on HuggingFace (used with the Inference API)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Must match the model's actual output dimension
EMBEDDING_DIM=384
# Batch size for bulk ingestion API calls
EMBEDDING_BATCH_SIZE=32
# HuggingFace Inference API base URL (feature-extraction pipeline)
HUGGINGFACE_API_URL=https://api-inference.huggingface.co/pipeline/feature-extraction
# Timeout in seconds per HuggingFace API call
HUGGINGFACE_TIMEOUT=30
# Max retries on HuggingFace 429/503/timeout errors
HUGGINGFACE_MAX_RETRIES=3

# ─────────────────────────── Application ──────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
# Maximum allowed PDF upload size in megabytes
MAX_UPLOAD_SIZE_MB=50
# JSON array of allowed CORS origins — set to your frontend domain in production
# WARNING: Do NOT use ["*"] in production (see AUDIT_REPORT.md FINDING-001)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
# Seconds before a completed job entry expires from the in-memory store
JOB_TTL_SECONDS=86400

# ─────────────────────────── Logging ──────────────────────────────────────────
# Options: json | console
LOG_FORMAT=json
LOG_LEVEL=INFO
